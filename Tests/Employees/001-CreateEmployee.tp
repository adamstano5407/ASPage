--- TESTCASE 001-CreateEmployee

--- INIT
#load "../../.teapie/Definitions/Employee/Employee.csx"
#load "../../.teapie/Definitions/Generator.csx"


var employee = GenerateEmployee();

tp.SetVariable("NewEmployee", employee.ToJsonString(), "employees");

--- HTTP
### Create Employee
# @name CreateEmployeeRequest
POST {{APP_URL}}{{EmployeesEndpoint}}
Content-Type: application/json

{{NewEmployee}}

### Get Created Employee
# @name GetCreatedEmployeeRequest
GET {{APP_URL}}{{EmployeesEndpoint}}/{{CreateEmployeeRequest.response.body.$.id}}

--- TEST

var newEmployee = tp.GetVariable<string>("NewEmployee");
dynamic expected = newEmployee.ToExpando();

await tp.Test("Create employee should return 201.", async () =>
{
    var body = await tp.Responses["CreateEmployeeRequest"].GetBodyAsync();
    Console.WriteLine(body);

    Equal(201, tp.Responses["CreateEmployeeRequest"].StatusCode());
});

await tp.Test("Created employee should match request body.", async () =>
{
    dynamic created = await tp.Responses["CreateEmployeeRequest"].GetBodyAsExpandoAsync();

    True(created.id > 0);
    Equal(expected.employeeNumber, created.employeeNumber);
    Equal(expected.title, created.title);
    Equal(expected.firstName, created.firstName);
    Equal(expected.lastName, created.lastName);
    Equal(expected.email, created.email);
    Equal(expected.phone, created.phone);
    Equal(expected.companyId, created.companyId);
});

tp.Test("Get created employee should return 200.", () =>
{
    Equal(200, tp.Responses["GetCreatedEmployeeRequest"].StatusCode());
});

await tp.Test("Retrieved employee should match created employee.", async () =>
{
    dynamic created = await tp.Responses["CreateEmployeeRequest"].GetBodyAsExpandoAsync();
    dynamic retrieved = await tp.Responses["GetCreatedEmployeeRequest"].GetBodyAsExpandoAsync();

    Equal(created.id, retrieved.id);
    Equal(created.employeeNumber, retrieved.employeeNumber);
    Equal(created.email, retrieved.email);
});

--- END