--- TESTCASE 001-CreateOrganizationHierarchyAndCascadeDelete

--- INIT
#load "../.teapie/Definitions/Company/Company.csx"
#load "../.teapie/Definitions/Division/Division.csx"
#load "../.teapie/Definitions/Project/Project.csx"
#load "../.teapie/Definitions/Department/Department.csx"
#load "../.teapie/Definitions/Employee/Employee.csx"
#load "../.teapie/Definitions/Generator.csx"
#load "../.teapie/Definitions/SetObjectVariable.csx"

const string Tag = "hierarchy-001";

var company = GenerateCompany();
var employee = GenerateEmployee();
var division = GenerateDivision();
var project = GenerateProject();
var department = GenerateDepartment();

tp.SetVariable("Company", company.ToJsonString(), Tag);
SetObjectVariables("Employee", employee, Tag);
SetObjectVariables("Division", division, Tag);
SetObjectVariables("Project", project, Tag);
SetObjectVariables("Department", department, Tag);


--- HTTP

### Create Company
# @name CreateCompanyRequest
POST {{APP_URL}}/api/companies
Content-Type: application/json

{{Company}}

### Create Employee
# @name CreateEmployeeRequest
POST {{APP_URL}}/api/employees
Content-Type: application/json

{
  "employeeNumber": "{{EmployeeEmployeeNumber}}",
  "title": "{{EmployeeTitle}}",
  "firstName": "{{EmployeeFirstName}}",
  "lastName": "{{EmployeeLastName}}",
  "email": "{{EmployeeEmail}}",
  "phone": "{{EmployeePhone}}",
  "companyId": {{CreateCompanyRequest.response.body.$.id}}
}

### Create Division
# @name CreateDivisionRequest
POST {{APP_URL}}/api/divisions
Content-Type: application/json

{
  "name": "{{DivisionName}}",
  "code": "{{DivisionCode}}",
  "managerId": {{CreateEmployeeRequest.response.body.$.id}},
  "parentId": {{CreateCompanyRequest.response.body.$.id}}
}

### Create Project
# @name CreateProjectRequest
POST {{APP_URL}}/api/projects
Content-Type: application/json

{
  "name": "{{ProjectName}}",
  "code": "{{ProjectCode}}",
  "managerId": {{CreateEmployeeRequest.response.body.$.id}},
  "parentId": {{CreateDivisionRequest.response.body.$.id}}
}

### Create Department
# @name CreateDepartmentRequest
POST {{APP_URL}}/api/departments
Content-Type: application/json

{
  "name": "{{DepartmentName}}",
  "code": "{{DepartmentCode}}",
  "managerId": {{CreateEmployeeRequest.response.body.$.id}},
  "parentId": {{CreateProjectRequest.response.body.$.id}}
}

### Get Company
# @name GetCompanyRequest
GET {{APP_URL}}/api/companies/{{CreateCompanyRequest.response.body.$.id}}

### Get Employee
# @name GetEmployeeRequest
GET {{APP_URL}}/api/employees/{{CreateEmployeeRequest.response.body.$.id}}

### Get Division
# @name GetDivisionRequest
GET {{APP_URL}}/api/divisions/{{CreateDivisionRequest.response.body.$.id}}

### Get Project
# @name GetProjectRequest
GET {{APP_URL}}/api/projects/{{CreateProjectRequest.response.body.$.id}}

### Get Department
# @name GetDepartmentRequest
GET {{APP_URL}}/api/departments/{{CreateDepartmentRequest.response.body.$.id}}


### Delete Company
# @name DeleteCompanyRequest
DELETE {{APP_URL}}/api/companies/{{CreateCompanyRequest.response.body.$.id}}

### Get Deleted Company
# @name GetDeletedCompanyRequest
GET {{APP_URL}}/api/companies/{{CreateCompanyRequest.response.body.$.id}}

### Get Deleted Employee
# @name GetDeletedEmployeeRequest
GET {{APP_URL}}/api/employees/{{CreateEmployeeRequest.response.body.$.id}}

### Get Deleted Division
# @name GetDeletedDivisionRequest
GET {{APP_URL}}/api/divisions/{{CreateDivisionRequest.response.body.$.id}}

### Get Deleted Project
# @name GetDeletedProjectRequest
GET {{APP_URL}}/api/projects/{{CreateProjectRequest.response.body.$.id}}

### Get Deleted Department
# @name GetDeletedDepartmentRequest
GET {{APP_URL}}/api/departments/{{CreateDepartmentRequest.response.body.$.id}}

--- TEST
const string Tag = "hierarchy-001";


tp.Test("Hierarchy should be created.", () =>
{
    Equal(201, tp.Responses["CreateCompanyRequest"].StatusCode());
    Equal(201, tp.Responses["CreateEmployeeRequest"].StatusCode());
    Equal(201, tp.Responses["CreateDivisionRequest"].StatusCode());
    Equal(201, tp.Responses["CreateProjectRequest"].StatusCode());
    Equal(201, tp.Responses["CreateDepartmentRequest"].StatusCode());
});

tp.Test("Created hierarchy should be retrievable.", () =>
{
    Equal(200, tp.Responses["GetCompanyRequest"].StatusCode());
    Equal(200, tp.Responses["GetEmployeeRequest"].StatusCode());
    Equal(200, tp.Responses["GetDivisionRequest"].StatusCode());
    Equal(200, tp.Responses["GetProjectRequest"].StatusCode());
    Equal(200, tp.Responses["GetDepartmentRequest"].StatusCode());
});

dynamic company = await tp.Responses["CreateCompanyRequest"].GetBodyAsExpandoAsync();
dynamic employee = await tp.Responses["CreateEmployeeRequest"].GetBodyAsExpandoAsync();
dynamic division = await tp.Responses["CreateDivisionRequest"].GetBodyAsExpandoAsync();
dynamic project = await tp.Responses["CreateProjectRequest"].GetBodyAsExpandoAsync();
dynamic department = await tp.Responses["CreateDepartmentRequest"].GetBodyAsExpandoAsync();

tp.Test("Created entities should have ids.", () =>
{
    True(company.id > 0);
    True(employee.id > 0);
    True(division.id > 0);
    True(project.id > 0);
    True(department.id > 0);
});

tp.Test("Employee should belong to created company.", () =>
{
    Equal(company.id, employee.companyId);
});

tp.Test("Division should belong to company and use employee as manager.", () =>
{
    Equal(company.id, division.companyId);
    Equal(employee.id, division.managerId);
});

tp.Test("Project should belong to division and use employee as manager.", () =>
{
    Equal(division.id, project.divisionId);
    Equal(employee.id, project.managerId);
});

tp.Test("Department should belong to project and use employee as manager.", () =>
{
    Equal(project.id, department.projectId);
    Equal(employee.id, department.managerId);
});

tp.Test("Company should be deleted.", () =>
{
    Equal(204, tp.Responses["DeleteCompanyRequest"].StatusCode());
});

tp.Test("Deleted hierarchy should not be found.", () =>
{
    var deletedRequestNames = new[]
    {
        "GetDeletedCompanyRequest",
        "GetDeletedEmployeeRequest",
        "GetDeletedDivisionRequest",
        "GetDeletedProjectRequest",
        "GetDeletedDepartmentRequest"
    };

    foreach (var name in deletedRequestNames)
        Equal(404, tp.Responses[name].StatusCode());
});

tp.RemoveVariablesWithTag("hierarchy-001");


--- END
