POST {{APP_URL}}{{EmployeesEndpoint}}
Content-Type: application/json

{{NullPhone}}

--- TEST

string[] requestNames =
{
  "MissingEmployeeNumberRequest",
  "InvalidTitleRequest",
  "InvalidFirstNameRequest",
  "InvalidLastNameRequest",
  "InvalidEmailRequest",
  "InvalidPhoneRequest",
  "InvalidCompanyIdRequest",
  "NullEmployeeNumberRequest",
  "NullFirstNameRequest",
  "NullLastNameRequest",
  "NullEmailRequest",
  "NullPhoneRequest"
};

foreach (var requestName in requestNames)
{
await tp.Test($"{requestName} should return 400.", async () =>
{
var body = await tp.Responses[requestName].GetBodyAsync();
Console.WriteLine(body);

Equal(400, tp.Responses[requestName].StatusCode());
});
}

--- END