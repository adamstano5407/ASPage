--- TESTCASE 003-CreateEmployeeDifferentValuesThanExpected

--- INIT
#load "../../.teapie/Definitions/Employee/Employee.csx"
#load "../../.teapie/Definitions/Generator.csx"

var missingEmployeeNumber = GenerateEmployee();
missingEmployeeNumber.EmployeeNumber = "";

var invalidTitle = GenerateEmployee();
invalidTitle.Title = "InvalidTitle";

var invalidFirstName = GenerateEmployee();
invalidFirstName.FirstName = "John123";

var invalidLastName = GenerateEmployee();
invalidLastName.LastName = "Doe123";

var invalidEmail = GenerateEmployee();
invalidEmail.Email = "not-email";

var invalidPhone = GenerateEmployee();
invalidPhone.Phone = "abc-phone";

var invalidCompanyId = GenerateEmployee();
invalidCompanyId.CompanyId = -1;

tp.SetVariable("MissingEmployeeNumber", missingEmployeeNumber.ToJsonString(), "employees");
tp.SetVariable("InvalidTitle", invalidTitle.ToJsonString(), "employees");
tp.SetVariable("InvalidFirstName", invalidFirstName.ToJsonString(), "employees");
tp.SetVariable("InvalidLastName", invalidLastName.ToJsonString(), "employees");
tp.SetVariable("InvalidEmail", invalidEmail.ToJsonString(), "employees");
tp.SetVariable("InvalidPhone", invalidPhone.ToJsonString(), "employees");
tp.SetVariable("InvalidCompanyId", invalidCompanyId.ToJsonString(), "employees");

var nullEmployeeNumber = GenerateEmployee();
nullEmployeeNumber.EmployeeNumber = null;

var nullFirstName = GenerateEmployee();
nullFirstName.FirstName = null;

var nullLastName = GenerateEmployee();
nullLastName.LastName = null;

var nullEmail = GenerateEmployee();
nullEmail.Email = null;

var nullPhone = GenerateEmployee();
nullPhone.Phone = null;

tp.SetVariable("NullEmployeeNumber", nullEmployeeNumber.ToJsonString(), "employees");
tp.SetVariable("NullFirstName", nullFirstName.ToJsonString(), "employees");
tp.SetVariable("NullLastName", nullLastName.ToJsonString(), "employees");
tp.SetVariable("NullEmail", nullEmail.ToJsonString(), "employees");
tp.SetVariable("NullPhone", nullPhone.ToJsonString(), "employees");


--- HTTP
### Missing Employee Number
# @name MissingEmployeeNumberRequest
POST {{APP_URL}}{{EmployeesEndpoint}}
Content-Type: application/json

{{MissingEmployeeNumber}}

### Invalid Title
