--- TESTCASE 002-ComplexCreateAndDeleteHierarchy

--- INIT
#load "../../.teapie/Definitions/Company/Company.csx"
#load "../../.teapie/Definitions/Division/Division.csx"
#load "../../.teapie/Definitions/Project/Project.csx"
#load "../../.teapie/Definitions/Department/Department.csx"
#load "../../.teapie/Definitions/Employee/Employee.csx"
#load "../../.teapie/Definitions/Generator.csx"

var company = GenerateCompany();
var employee = GenerateEmployee();

var divisionA = GenerateDivision();
var divisionB = GenerateDivision();

var projectA = GenerateProject();
var projectB = GenerateProject();

var departmentA = GenerateDepartment();
var departmentB = GenerateDepartment();
var departmentC = GenerateDepartment();

tp.SetVariable("Company", company.ToJsonString(), "hierarchy");

tp.SetVariable("EmployeeNumber", employee.EmployeeNumber, "hierarchy");
tp.SetVariable("EmployeeTitle", employee.Title ?? "Mgr.", "hierarchy");
tp.SetVariable("EmployeeFirstName", employee.FirstName, "hierarchy");
tp.SetVariable("EmployeeLastName", employee.LastName, "hierarchy");
tp.SetVariable("EmployeeEmail", employee.Email, "hierarchy");
tp.SetVariable("EmployeePhone", employee.Phone, "hierarchy");

tp.SetVariable("DivisionAName", divisionA.Name, "hierarchy");
tp.SetVariable("DivisionACode", divisionA.Code, "hierarchy");
tp.SetVariable("DivisionBName", divisionB.Name, "hierarchy");
tp.SetVariable("DivisionBCode", divisionB.Code, "hierarchy");

tp.SetVariable("ProjectAName", projectA.Name, "hierarchy");
tp.SetVariable("ProjectACode", projectA.Code, "hierarchy");
tp.SetVariable("ProjectBName", projectB.Name, "hierarchy");
tp.SetVariable("ProjectBCode", projectB.Code, "hierarchy");

tp.SetVariable("DepartmentAName", departmentA.Name, "hierarchy");
tp.SetVariable("DepartmentACode", departmentA.Code, "hierarchy");
tp.SetVariable("DepartmentBName", departmentB.Name, "hierarchy");
tp.SetVariable("DepartmentBCode", departmentB.Code, "hierarchy");
tp.SetVariable("DepartmentCName", departmentC.Name, "hierarchy");
tp.SetVariable("DepartmentCCode", departmentC.Code, "hierarchy");

--- HTTP

### Create Company
# @name CreateCompanyRequest
POST {{APP_URL}}{{CompaniesEndpoint}}
Content-Type: application/json

{{Company}}

### Create Employee
# @name CreateEmployeeRequest
POST {{APP_URL}}{{EmployeesEndpoint}}
Content-Type: application/json

{
  "title": "{{EmployeeTitle}}",
  "employeeNumber": "{{EmployeeNumber}}",
  "firstName": "{{EmployeeFirstName}}",
  "lastName": "{{EmployeeLastName}}",
  "email": "{{EmployeeEmail}}",
  "phone": "{{EmployeePhone}}",
  "companyId": {{CreateCompanyRequest.response.body.$.id}}
}

### Create Division A
# @name CreateDivisionARequest
POST {{APP_URL}}{{DivisionsEndpoint}}
Content-Type: application/json

{
  "name": "{{DivisionAName}}",
  "code": "{{DivisionACode}}",
  "managerId": {{CreateEmployeeRequest.response.body.$.id}},
  "parentId": {{CreateCompanyRequest.response.body.$.id}}
}

### Create Division B
# @name CreateDivisionBRequest
POST {{APP_URL}}{{DivisionsEndpoint}}
Content-Type: application/json

{
  "name": "{{DivisionBName}}",
  "code": "{{DivisionBCode}}",
  "managerId": {{CreateEmployeeRequest.response.body.$.id}},
  "parentId": {{CreateCompanyRequest.response.body.$.id}}
}

### Create Project A
# @name CreateProjectARequest
POST {{APP_URL}}{{ProjectsEndpoint}}
Content-Type: application/json

{
  "name": "{{ProjectAName}}",
  "code": "{{ProjectACode}}",
  "managerId": {{CreateEmployeeRequest.response.body.$.id}},
  "parentId": {{CreateDivisionARequest.response.body.$.id}}
}

### Create Project B
# @name CreateProjectBRequest
POST {{APP_URL}}{{ProjectsEndpoint}}
Content-Type: application/json

{
  "name": "{{ProjectBName}}",
  "code": "{{ProjectBCode}}",
  "managerId": {{CreateEmployeeRequest.response.body.$.id}},
  "parentId": {{CreateDivisionBRequest.response.body.$.id}}
}

### Create Department A
# @name CreateDepartmentARequest
POST {{APP_URL}}{{DepartmentsEndpoint}}
Content-Type: application/json

{
  "name": "{{DepartmentAName}}",
  "code": "{{DepartmentACode}}",
  "managerId": {{CreateEmployeeRequest.response.body.$.id}},
  "parentId": {{CreateProjectARequest.response.body.$.id}}
}

### Create Department B
# @name CreateDepartmentBRequest
POST {{APP_URL}}{{DepartmentsEndpoint}}
Content-Type: application/json

{
  "name": "{{DepartmentBName}}",
  "code": "{{DepartmentBCode}}",
  "managerId": {{CreateEmployeeRequest.response.body.$.id}},
  "parentId": {{CreateProjectARequest.response.body.$.id}}
}

### Create Department C
# @name CreateDepartmentCRequest
POST {{APP_URL}}{{DepartmentsEndpoint}}
Content-Type: application/json

{
  "name": "{{DepartmentCName}}",
  "code": "{{DepartmentCCode}}",
  "managerId": {{CreateEmployeeRequest.response.body.$.id}},
  "parentId": {{CreateProjectBRequest.response.body.$.id}}
}

### Get Company Divisions
# @name GetCompanyDivisionsRequest
GET {{APP_URL}}{{CompaniesEndpoint}}/{{CreateCompanyRequest.response.body.$.id}}/divisions

### Get Company Projects
# @name GetCompanyProjectsRequest
GET {{APP_URL}}{{CompaniesEndpoint}}/{{CreateCompanyRequest.response.body.$.id}}/projects

### Get Company Departments
# @name GetCompanyDepartmentsRequest
GET {{APP_URL}}{{CompaniesEndpoint}}/{{CreateCompanyRequest.response.body.$.id}}/departments

### Get Division A Projects
# @name GetDivisionAProjectsRequest
GET {{APP_URL}}{{DivisionsEndpoint}}/{{CreateDivisionARequest.response.body.$.id}}/projects

### Get Project A Departments
# @name GetProjectADepartmentsRequest
GET {{APP_URL}}{{ProjectsEndpoint}}/{{CreateProjectARequest.response.body.$.id}}/departments

### Delete Project A Departments
# @name DeleteProjectADepartmentsRequest
DELETE {{APP_URL}}{{ProjectsEndpoint}}/{{CreateProjectARequest.response.body.$.id}}/departments

### Get Project A Departments After Delete
# @name GetProjectADepartmentsAfterDeleteRequest
GET {{APP_URL}}{{ProjectsEndpoint}}/{{CreateProjectARequest.response.body.$.id}}/departments

### Get Company Departments After Project Department Delete
# @name GetCompanyDepartmentsAfterProjectDepartmentDeleteRequest
GET {{APP_URL}}{{CompaniesEndpoint}}/{{CreateCompanyRequest.response.body.$.id}}/departments

### Delete Division A Projects
# @name DeleteDivisionAProjectsRequest
DELETE {{APP_URL}}{{DivisionsEndpoint}}/{{CreateDivisionARequest.response.body.$.id}}/projects

### Get Division A Projects After Delete
# @name GetDivisionAProjectsAfterDeleteRequest
GET {{APP_URL}}{{DivisionsEndpoint}}/{{CreateDivisionARequest.response.body.$.id}}/projects

### Get Company Projects After Division Projects Delete
# @name GetCompanyProjectsAfterDivisionProjectsDeleteRequest
GET {{APP_URL}}{{CompaniesEndpoint}}/{{CreateCompanyRequest.response.body.$.id}}/projects

### Get Company Departments After Division Projects Delete
# @name GetCompanyDepartmentsAfterDivisionProjectsDeleteRequest
GET {{APP_URL}}{{CompaniesEndpoint}}/{{CreateCompanyRequest.response.body.$.id}}/departments

### Delete Company Divisions
# @name DeleteCompanyDivisionsRequest
DELETE {{APP_URL}}{{CompaniesEndpoint}}/{{CreateCompanyRequest.response.body.$.id}}/divisions

### Get Company Divisions After Delete
# @name GetCompanyDivisionsAfterDeleteRequest
GET {{APP_URL}}{{CompaniesEndpoint}}/{{CreateCompanyRequest.response.body.$.id}}/divisions

### Get Company Projects After Company Divisions Delete
# @name GetCompanyProjectsAfterCompanyDivisionsDeleteRequest
GET {{APP_URL}}{{CompaniesEndpoint}}/{{CreateCompanyRequest.response.body.$.id}}/projects

### Get Company Departments After Company Divisions Delete
# @name GetCompanyDepartmentsAfterCompanyDivisionsDeleteRequest
GET {{APP_URL}}{{CompaniesEndpoint}}/{{CreateCompanyRequest.response.body.$.id}}/departments

### Delete Company
# @name DeleteCompanyRequest
DELETE {{APP_URL}}{{CompaniesEndpoint}}/{{CreateCompanyRequest.response.body.$.id}}

### Get Company After Delete
# @name GetCompanyAfterDeleteRequest
GET {{APP_URL}}{{CompaniesEndpoint}}/{{CreateCompanyRequest.response.body.$.id}}

### Get Employee After Company Delete
# @name GetEmployeeAfterCompanyDeleteRequest
GET {{APP_URL}}{{EmployeesEndpoint}}/{{CreateEmployeeRequest.response.body.$.id}}


--- TEST
using Newtonsoft.Json.Linq;

async Task<JArray> GetArray(string requestName)
{
    var body = await tp.Responses[requestName].GetBodyAsync();
    return JArray.Parse(body);
}

tp.Test("Company should be created.", () =>
{
    Equal(201, tp.Responses["CreateCompanyRequest"].StatusCode());
});

tp.Test("Employee should be created.", () =>
{
    Equal(201, tp.Responses["CreateEmployeeRequest"].StatusCode());
});

tp.Test("Hierarchy should be created.", () =>
{
    Equal(201, tp.Responses["CreateDivisionARequest"].StatusCode());
    Equal(201, tp.Responses["CreateDivisionBRequest"].StatusCode());
    Equal(201, tp.Responses["CreateProjectARequest"].StatusCode());
    Equal(201, tp.Responses["CreateProjectBRequest"].StatusCode());
    Equal(201, tp.Responses["CreateDepartmentARequest"].StatusCode());
    Equal(201, tp.Responses["CreateDepartmentBRequest"].StatusCode());
    Equal(201, tp.Responses["CreateDepartmentCRequest"].StatusCode());
});

await tp.Test("Created hierarchy should have correct relations.", async () =>
{
    dynamic company = await tp.Responses["CreateCompanyRequest"].GetBodyAsExpandoAsync();
   dynamic employee = await tp.Responses["CreateEmployeeRequest"].GetBodyAsExpandoAsync();
    
    dynamic divisionA = await tp.Responses["CreateDivisionARequest"].GetBodyAsExpandoAsync();
    dynamic divisionB = await tp.Responses["CreateDivisionBRequest"].GetBodyAsExpandoAsync();

    dynamic projectA = await tp.Responses["CreateProjectARequest"].GetBodyAsExpandoAsync();
    dynamic projectB = await tp.Responses["CreateProjectBRequest"].GetBodyAsExpandoAsync();

    dynamic departmentA = await tp.Responses["CreateDepartmentARequest"].GetBodyAsExpandoAsync();
    dynamic departmentB = await tp.Responses["CreateDepartmentBRequest"].GetBodyAsExpandoAsync();
    dynamic departmentC = await tp.Responses["CreateDepartmentCRequest"].GetBodyAsExpandoAsync();

    True(company.id > 0);
    True(employee.Id > 0);
   
    Equal(company.id, divisionA.companyId);
    Equal(company.id, divisionB.companyId);

  
    Equal(employee.Id, divisionA.managerId);
    Equal(employee.Id, divisionB.managerId);

    Equal(divisionA.id, projectA.divisionId);
    Equal(divisionB.id, projectB.divisionId);

    Equal(projectA.id, departmentA.projectId);
    Equal(projectA.id, departmentB.projectId);
    Equal(projectB.id, departmentC.projectId);
});

await tp.Test("Company should contain two divisions.", async () =>
{
    var divisions = await GetArray("GetCompanyDivisionsRequest");
    Equal(2, divisions.Count);
});

await tp.Test("Company should contain two projects.", async () =>
{
    var projects = await GetArray("GetCompanyProjectsRequest");
    Equal(2, projects.Count);
});

await tp.Test("Company should contain three departments.", async () =>
{
    var departments = await GetArray("GetCompanyDepartmentsRequest");
    Equal(3, departments.Count);
});

await tp.Test("Division A should contain one project.", async () =>
{
    var projects = await GetArray("GetDivisionAProjectsRequest");
    Equal(1, projects.Count);
});

await tp.Test("Project A should contain two departments.", async () =>
{
    var departments = await GetArray("GetProjectADepartmentsRequest");
    Equal(2, departments.Count);
});

tp.Test("Project A departments should be deleted.", () =>
{
    Equal(204, tp.Responses["DeleteProjectADepartmentsRequest"].StatusCode());
});

await tp.Test("Project A should contain zero departments after delete.", async () =>
{
    var departments = await GetArray("GetProjectADepartmentsAfterDeleteRequest");
    Equal(0, departments.Count);
});

await tp.Test("Company should contain only one department after deleting Project A departments.", async () =>
{
    var departments = await GetArray("GetCompanyDepartmentsAfterProjectDepartmentDeleteRequest");
    Equal(1, departments.Count);
});

tp.Test("Division A projects should be deleted.", () =>
{
    Equal(204, tp.Responses["DeleteDivisionAProjectsRequest"].StatusCode());
});

await tp.Test("Division A should contain zero projects after delete.", async () =>
{
    var projects = await GetArray("GetDivisionAProjectsAfterDeleteRequest");
    Equal(0, projects.Count);
});

await tp.Test("Company should contain only one project after deleting Division A projects.", async () =>
{
    var projects = await GetArray("GetCompanyProjectsAfterDivisionProjectsDeleteRequest");
    Equal(1, projects.Count);
});

await tp.Test("Company should still contain one department after deleting empty Division A projects.", async () =>
{
    var departments = await GetArray("GetCompanyDepartmentsAfterDivisionProjectsDeleteRequest");
    Equal(1, departments.Count);
});

tp.Test("Company divisions should be deleted.", () =>
{
    Equal(204, tp.Responses["DeleteCompanyDivisionsRequest"].StatusCode());
});

await tp.Test("Company should contain zero divisions after delete.", async () =>
{
    var divisions = await GetArray("GetCompanyDivisionsAfterDeleteRequest");
    Equal(0, divisions.Count);
});

await tp.Test("Company should contain zero projects after deleting all divisions.", async () =>
{
    var projects = await GetArray("GetCompanyProjectsAfterCompanyDivisionsDeleteRequest");
    Equal(0, projects.Count);
});

await tp.Test("Company should contain zero departments after deleting all divisions.", async () =>
{
    var departments = await GetArray("GetCompanyDepartmentsAfterCompanyDivisionsDeleteRequest");
    Equal(0, departments.Count);
});

tp.Test("Company should be deleted.", () =>
{
    Equal(204, tp.Responses["DeleteCompanyRequest"].StatusCode());
});

tp.Test("Company should not be found after delete.", () =>
{
    Equal(404, tp.Responses["GetCompanyAfterDeleteRequest"].StatusCode());
});

tp.Test("Employee should be deleted by company cascade.", () =>
{
    Equal(404, tp.Responses["GetEmployeeAfterCompanyDeleteRequest"].StatusCode());
});

--- END