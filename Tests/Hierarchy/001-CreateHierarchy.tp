--- TESTCASE 001-CreateHierarchy

--- INIT
#load "../../.teapie/Definitions/Company/Company.csx"
#load "../../.teapie/Definitions/Division/Division.csx"
#load "../../.teapie/Definitions/Project/Project.csx"
#load "../../.teapie/Definitions/Department/Department.csx"
#load "../../.teapie/Definitions/Employee/Employee.csx"
#load "../../.teapie/Definitions/Generator.csx"

var company = GenerateCompany();
var division = GenerateDivision();
var project = GenerateProject();
var department = GenerateDepartment();
var employee = GenerateEmployee();

tp.SetVariable("Company", company.ToJsonString(), "hierarchy");

tp.SetVariable("DivisionName", division.Name, "hierarchy");
tp.SetVariable("DivisionCode", division.Code, "hierarchy");

tp.SetVariable("ProjectName", project.Name, "hierarchy");
tp.SetVariable("ProjectCode", project.Code, "hierarchy");

tp.SetVariable("DepartmentName", department.Name, "hierarchy");
tp.SetVariable("DepartmentCode", department.Code, "hierarchy");

tp.SetVariable("EmployeeNumber", employee.EmployeeNumber, "hierarchy");
tp.SetVariable("EmployeeTitle", employee.Title ?? "Mgr.", "hierarchy");
tp.SetVariable("EmployeeFirstName", employee.FirstName, "hierarchy");
tp.SetVariable("EmployeeLastName", employee.LastName, "hierarchy");
tp.SetVariable("EmployeeEmail", employee.Email, "hierarchy");
tp.SetVariable("EmployeePhone", employee.Phone, "hierarchy");

--- HTTP

### Create Company
# @name CreateCompanyRequest
POST {{APP_URL}}/api/companies
Content-Type: application/json

{{Company}}

### Create Employee
# @name CreateEmployeeRequest
POST {{APP_URL}}/api/employees
Content-Type: application/json

{
  "employeeNumber": "{{EmployeeNumber}}",
  "title": "{{EmployeeTitle}}",
  "firstName": "{{EmployeeFirstName}}",
  "lastName": "{{EmployeeLastName}}",
  "email": "{{EmployeeEmail}}",
  "phone": "{{EmployeePhone}}",
  "companyId": {{CreateCompanyRequest.response.body.$.id}}
}
### Create Division
# @name CreateDivisionRequest
POST {{APP_URL}}/api/divisions
Content-Type: application/json

{
  "name": "{{DivisionName}}",
  "code": "{{DivisionCode}}",
  "managerId": {{CreateEmployeeRequest.response.body.$.id}},
  "parentId": {{CreateCompanyRequest.response.body.$.id}}
}

### Create Project
# @name CreateProjectRequest
POST {{APP_URL}}/api/projects
Content-Type: application/json

{
  "name": "{{ProjectName}}",
  "code": "{{ProjectCode}}",
  "managerId": {{CreateEmployeeRequest.response.body.$.id}},
  "parentId": {{CreateDivisionRequest.response.body.$.id}}
}
### Create Department
# @name CreateDepartmentRequest
POST {{APP_URL}}/api/departments
Content-Type: application/json

{
  "name": "{{DepartmentName}}",
  "code": "{{DepartmentCode}}",
  "managerId": {{CreateEmployeeRequest.response.body.$.id}},
  "parentId": {{CreateProjectRequest.response.body.$.id}}
}

### Delete Company
# @name DeleteCompanyRequest
DELETE {{APP_URL}}/api/companies/{{CreateCompanyRequest.response.body.$.id}}

### Get Deleted Company
# @name GetDeletedCompanyRequest
GET {{APP_URL}}/api/companies/{{CreateCompanyRequest.response.body.$.id}}

### Get Deleted Employee
# @name GetDeletedEmployeeRequest
GET {{APP_URL}}/api/employees/{{CreateEmployeeRequest.response.body.$.id}}

### Get Deleted Division
# @name GetDeletedDivisionRequest
GET {{APP_URL}}/api/divisions/{{CreateDivisionRequest.response.body.$.id}}

### Get Deleted Project
# @name GetDeletedProjectRequest
GET {{APP_URL}}/api/projects/{{CreateProjectRequest.response.body.$.id}}

### Get Deleted Department
# @name GetDeletedDepartmentRequest
GET {{APP_URL}}/api/departments/{{CreateDepartmentRequest.response.body.$.id}}

--- TEST

tp.Test("Hierarchy should be created.", () =>
{
    Equal(201, tp.Responses["CreateCompanyRequest"].StatusCode());
    Equal(201, tp.Responses["CreateEmployeeRequest"].StatusCode());
    Equal(201, tp.Responses["CreateDivisionRequest"].StatusCode());
    Equal(201, tp.Responses["CreateProjectRequest"].StatusCode());
    Equal(201, tp.Responses["CreateDepartmentRequest"].StatusCode());
});

await tp.Test("Created hierarchy should have correct relations.", async () =>
{
    dynamic createdCompany = await tp.Responses["CreateCompanyRequest"].GetBodyAsExpandoAsync();
    dynamic createdEmployee = await tp.Responses["CreateEmployeeRequest"].GetBodyAsExpandoAsync();
    dynamic createdDivision = await tp.Responses["CreateDivisionRequest"].GetBodyAsExpandoAsync();
    dynamic createdProject = await tp.Responses["CreateProjectRequest"].GetBodyAsExpandoAsync();
    dynamic createdDepartment = await tp.Responses["CreateDepartmentRequest"].GetBodyAsExpandoAsync();

    True(createdCompany.id > 0);
    True(createdEmployee.id > 0);
    True(createdDivision.id > 0);
    True(createdProject.id > 0);
    True(createdDepartment.id > 0);

    Equal(createdCompany.id, createdEmployee.companyId);

    Equal(createdCompany.id, createdDivision.companyId);
    Equal(createdEmployee.id, createdDivision.managerId);

    Equal(createdDivision.id, createdProject.divisionId);
    Equal(createdEmployee.id, createdProject.managerId);

    Equal(createdProject.id, createdDepartment.projectId);
    Equal(createdEmployee.id, createdDepartment.managerId);
});

tp.Test("Company should be deleted.", () =>
{
    Equal(204, tp.Responses["DeleteCompanyRequest"].StatusCode());
});

tp.Test("Deleted hierarchy should not be found.", () =>
{
    Equal(404, tp.Responses["GetDeletedCompanyRequest"].StatusCode());
    Equal(404, tp.Responses["GetDeletedEmployeeRequest"].StatusCode());
    Equal(404, tp.Responses["GetDeletedDivisionRequest"].StatusCode());
    Equal(404, tp.Responses["GetDeletedProjectRequest"].StatusCode());
    Equal(404, tp.Responses["GetDeletedDepartmentRequest"].StatusCode());
});

--- END