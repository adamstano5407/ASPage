POST {{APP_URL}}{{DivisionsEndpoint}}
Content-Type: application/json

{
  "name": "{{DivisionAName}}",
  "code": "{{DivisionACode}}",
  "managerId": {{CreateEmployeeToDeleteRequest.response.body.$.id}},
  "parentId": {{CreateCompanyRequest.response.body.$.id}}
}

