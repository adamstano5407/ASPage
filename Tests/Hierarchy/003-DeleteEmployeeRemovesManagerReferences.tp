--- TESTCASE 003-DeleteEmployeeRemovesManagerReferences

--- INIT
#load "../../.teapie/Definitions/Company/Company.csx"
#load "../../.teapie/Definitions/Division/Division.csx"
#load "../../.teapie/Definitions/Project/Project.csx"
#load "../../.teapie/Definitions/Department/Department.csx"
#load "../../.teapie/Definitions/Employee/Employee.csx"
#load "../../.teapie/Definitions/Generator.csx"

var company = GenerateCompany();

var employeeToDelete = GenerateEmployee();
var employeeToKeep = GenerateEmployee();

var divisionA = GenerateDivision();
var divisionB = GenerateDivision();
var divisionC = GenerateDivision();

var projectA1 = GenerateProject();
var projectA2 = GenerateProject();
var projectB1 = GenerateProject();
var projectC1 = GenerateProject();

var departmentA1 = GenerateDepartment();
var departmentA2 = GenerateDepartment();
var departmentB1 = GenerateDepartment();
var departmentC1 = GenerateDepartment();

tp.SetVariable("Company", company.ToJsonString(), "hierarchy");

tp.SetVariable("EmployeeToDeleteNumber", employeeToDelete.EmployeeNumber, "hierarchy");
tp.SetVariable("EmployeeToDeleteTitle", employeeToDelete.Title ?? "Mgr.", "hierarchy");
tp.SetVariable("EmployeeToDeleteFirstName", employeeToDelete.FirstName, "hierarchy");
tp.SetVariable("EmployeeToDeleteLastName", employeeToDelete.LastName, "hierarchy");
tp.SetVariable("EmployeeToDeleteEmail", employeeToDelete.Email, "hierarchy");
tp.SetVariable("EmployeeToDeletePhone", employeeToDelete.Phone, "hierarchy");

tp.SetVariable("EmployeeToKeepNumber", employeeToKeep.EmployeeNumber, "hierarchy");
tp.SetVariable("EmployeeToKeepTitle", employeeToKeep.Title ?? "Mgr.", "hierarchy");
tp.SetVariable("EmployeeToKeepFirstName", employeeToKeep.FirstName, "hierarchy");
tp.SetVariable("EmployeeToKeepLastName", employeeToKeep.LastName, "hierarchy");
tp.SetVariable("EmployeeToKeepEmail", employeeToKeep.Email, "hierarchy");
tp.SetVariable("EmployeeToKeepPhone", employeeToKeep.Phone, "hierarchy");

tp.SetVariable("DivisionAName", divisionA.Name, "hierarchy");
tp.SetVariable("DivisionACode", divisionA.Code, "hierarchy");
tp.SetVariable("DivisionBName", divisionB.Name, "hierarchy");
tp.SetVariable("DivisionBCode", divisionB.Code, "hierarchy");
tp.SetVariable("DivisionCName", divisionC.Name, "hierarchy");
tp.SetVariable("DivisionCCode", divisionC.Code, "hierarchy");

tp.SetVariable("ProjectA1Name", projectA1.Name, "hierarchy");
tp.SetVariable("ProjectA1Code", projectA1.Code, "hierarchy");
tp.SetVariable("ProjectA2Name", projectA2.Name, "hierarchy");
tp.SetVariable("ProjectA2Code", projectA2.Code, "hierarchy");
tp.SetVariable("ProjectB1Name", projectB1.Name, "hierarchy");
tp.SetVariable("ProjectB1Code", projectB1.Code, "hierarchy");
tp.SetVariable("ProjectC1Name", projectC1.Name, "hierarchy");
tp.SetVariable("ProjectC1Code", projectC1.Code, "hierarchy");

tp.SetVariable("DepartmentA1Name", departmentA1.Name, "hierarchy");
tp.SetVariable("DepartmentA1Code", departmentA1.Code, "hierarchy");
tp.SetVariable("DepartmentA2Name", departmentA2.Name, "hierarchy");
tp.SetVariable("DepartmentA2Code", departmentA2.Code, "hierarchy");
tp.SetVariable("DepartmentB1Name", departmentB1.Name, "hierarchy");
tp.SetVariable("DepartmentB1Code", departmentB1.Code, "hierarchy");
tp.SetVariable("DepartmentC1Name", departmentC1.Name, "hierarchy");
tp.SetVariable("DepartmentC1Code", departmentC1.Code, "hierarchy");

--- HTTP

### Create Company
# @name CreateCompanyRequest
POST {{APP_URL}}{{CompaniesEndpoint}}
Content-Type: application/json

{{Company}}

### Create Employee To Delete
# @name CreateEmployeeToDeleteRequest
POST {{APP_URL}}{{EmployeesEndpoint}}
Content-Type: application/json

{
  "title": "{{EmployeeToDeleteTitle}}",
  "employeeNumber": "{{EmployeeToDeleteNumber}}",
  "firstName": "{{EmployeeToDeleteFirstName}}",
  "lastName": "{{EmployeeToDeleteLastName}}",
  "email": "{{EmployeeToDeleteEmail}}",
  "phone": "{{EmployeeToDeletePhone}}",
  "companyId": {{CreateCompanyRequest.response.body.$.id}}
}

### Create Employee To Keep
# @name CreateEmployeeToKeepRequest
POST {{APP_URL}}{{EmployeesEndpoint}}
Content-Type: application/json

{
  "title": "{{EmployeeToKeepTitle}}",
  "employeeNumber": "{{EmployeeToKeepNumber}}",
  "firstName": "{{EmployeeToKeepFirstName}}",
  "lastName": "{{EmployeeToKeepLastName}}",
  "email": "{{EmployeeToKeepEmail}}",
  "phone": "{{EmployeeToKeepPhone}}",
  "companyId": {{CreateCompanyRequest.response.body.$.id}}
}

### Assign Company Director To Delete
# @name AssignCompanyDirectorRequest
PUT {{APP_URL}}{{CompaniesEndpoint}}/{{CreateCompanyRequest.response.body.$.id}}/director
Content-Type: application/json

{
  "employeeId": {{CreateEmployeeToDeleteRequest.response.body.$.id}}
}

