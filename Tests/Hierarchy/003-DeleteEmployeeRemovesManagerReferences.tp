### Delete Company
# @name DeleteCompanyRequest
DELETE {{APP_URL}}{{CompaniesEndpoint}}/{{CreateCompanyRequest.response.body.$.id}}

--- TEST

tp.Test("Company and employees should be created.", () =>
{
    Equal(201, tp.Responses["CreateCompanyRequest"].StatusCode());
    Equal(201, tp.Responses["CreateEmployeeToDeleteRequest"].StatusCode());
    Equal(201, tp.Responses["CreateEmployeeToKeepRequest"].StatusCode());
});

tp.Test("Company director should be assigned.", () =>
{
    Equal(200, tp.Responses["AssignCompanyDirectorRequest"].StatusCode());
});

tp.Test("Hierarchy should be created.", () =>
{
    Equal(201, tp.Responses["CreateDivisionARequest"].StatusCode());
    Equal(201, tp.Responses["CreateDivisionBRequest"].StatusCode());
    Equal(201, tp.Responses["CreateDivisionCRequest"].StatusCode());

    Equal(201, tp.Responses["CreateProjectA1Request"].StatusCode());
    Equal(201, tp.Responses["CreateProjectA2Request"].StatusCode());
    Equal(201, tp.Responses["CreateProjectB1Request"].StatusCode());
    Equal(201, tp.Responses["CreateProjectC1Request"].StatusCode());

    Equal(201, tp.Responses["CreateDepartmentA1Request"].StatusCode());
    Equal(201, tp.Responses["CreateDepartmentA2Request"].StatusCode());
    Equal(201, tp.Responses["CreateDepartmentB1Request"].StatusCode());
    Equal(201, tp.Responses["CreateDepartmentC1Request"].StatusCode());
});

tp.Test("Employee should be deleted.", () =>
{
    Equal(204, tp.Responses["DeleteEmployeeToDeleteRequest"].StatusCode());
});

tp.Test("Deleted employee should not be found.", () =>
{
    Equal(404, tp.Responses["GetDeletedEmployeeRequest"].StatusCode());
});

tp.Test("Employee to keep should still exist.", () =>
{
    Equal(200, tp.Responses["GetEmployeeToKeepRequest"].StatusCode());
});

await tp.Test("Deleted employee should be removed from manager references only.", async () =>
{
    dynamic employeeToKeep = await tp.Responses["CreateEmployeeToKeepRequest"].GetBodyAsExpandoAsync();

    dynamic company = await tp.Responses["GetCompanyAfterDeleteRequest"].GetBodyAsExpandoAsync();

    dynamic divisionA = await tp.Responses["GetDivisionAAfterDeleteRequest"].GetBodyAsExpandoAsync();
    dynamic divisionB = await tp.Responses["GetDivisionBAfterDeleteRequest"].GetBodyAsExpandoAsync();
    dynamic divisionC = await tp.Responses["GetDivisionCAfterDeleteRequest"].GetBodyAsExpandoAsync();

    dynamic projectA1 = await tp.Responses["GetProjectA1AfterDeleteRequest"].GetBodyAsExpandoAsync();
    dynamic projectA2 = await tp.Responses["GetProjectA2AfterDeleteRequest"].GetBodyAsExpandoAsync();
    dynamic projectB1 = await tp.Responses["GetProjectB1AfterDeleteRequest"].GetBodyAsExpandoAsync();
    dynamic projectC1 = await tp.Responses["GetProjectC1AfterDeleteRequest"].GetBodyAsExpandoAsync();

    dynamic departmentA1 = await tp.Responses["GetDepartmentA1AfterDeleteRequest"].GetBodyAsExpandoAsync();
    dynamic departmentA2 = await tp.Responses["GetDepartmentA2AfterDeleteRequest"].GetBodyAsExpandoAsync();
    dynamic departmentB1 = await tp.Responses["GetDepartmentB1AfterDeleteRequest"].GetBodyAsExpandoAsync();
    dynamic departmentC1 = await tp.Responses["GetDepartmentC1AfterDeleteRequest"].GetBodyAsExpandoAsync();

    True(company.managerId is null);

    True(divisionA.managerId is null);
    True(divisionB.managerId is null);
    Equal(employeeToKeep.id, divisionC.managerId);

    True(projectA1.managerId is null);
    Equal(employeeToKeep.id, projectA2.managerId);
    True(projectB1.managerId is null);
    Equal(employeeToKeep.id, projectC1.managerId);

    True(departmentA1.managerId is null);
    Equal(employeeToKeep.id, departmentA2.managerId);
    True(departmentB1.managerId is null);
    Equal(employeeToKeep.id, departmentC1.managerId);
});

--- END